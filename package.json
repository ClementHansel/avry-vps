{
  "name": "aivory-vps-panel",
  "version": "1.0.0",
  "description": "Aivory VPS Panel - Self-hosted Docker and server management dashboard built on Dockge (MIT)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:properties": "vitest run tests/properties",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "vps",
    "panel",
    "docker",
    "management",
    "aivory"
  ],
  "author": "Aivory",
  "license": "MIT",
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.500.0"
  },
  "dependencies": {
    "acme-client": "^5.3.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^3.5.3",
    "cron-parser": "^4.9.0",
    "dockerode": "^4.0.2",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "node-pty": "^1.0.0",
    "nodemailer": "^6.9.8",
    "simple-git": "^3.22.0",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/dockerode": "^3.3.23",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "fast-check": "^3.15.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
